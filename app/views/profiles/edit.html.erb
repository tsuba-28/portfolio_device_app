<div class="container mx-auto px-4 py-12 max-w-3xl">

  <% if @profile.errors.any? %>
    <div class="mb-6 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg">
      <ul class="list-disc list-inside text-sm">
        <% @profile.errors.full_messages.each do |message| %>
          <li><%= messages %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-[#94a3b8] rounded-[2rem] border-4 border-[#4182fa] shadow-2xl overflow-hidden relative">
    <%= form_with model: @profile, url: profile_path, method: 'put', local: true do |f| %>

      <div class="w-full relative group">

        <div class="w-full h-48 bg-[#4182fa] bg-cover bg-center transition-all duration-500" style="<%= "background-image: url(#{url_for(@profile.background)});" if @profile.background.attached? %>">
        </div>

        <div class="absolute bottom-4 right-4 z-10">
          <%= f.label :background, class: "w-10 h-10 bg-black/40 hover:bg-[#4182fa] text-white rounded-full flex items-center justify-center cursor-pointer backdrop-blur-sm transition-all border border-white/30 shadow-lg" do %>
            <i class="fas fa-camera"></i>
          <% end %>

          <%= f.file_field :background, class: "hidden", accept: 'image/*' %>
        </div>
      </div>

      <div class="px-8 pb-8">

        <div class="relative -mt-20 mb-6 flex justify-center">
          <div class="relative group">

            <div class="w-40 h-40 rounded-3xl bg-[#c7d2fe] border-4 border-white shadow-md overflow-hidden flex items-center justify-center bg-white">
              <% if @profile.avatar.attached? %>
                <%= image_tag @profile.avatar, data: { profile_image_target: "preview" }, class: "w-full h-full object-cover" %>
              <% else %>
                <img data-profile-image-target="preview" src="" class="w-full h-full object-cover hidden">
                <i class="fas fa-user text-6xl text-[#94a3b8] absolute"></i>
              <% end %>
            </div>

            <%= f.label :avatar, class: "absolute bottom-[-10px] right-[-10px] w-12 h-12 bg-[#94a1b8] rounded-full border-2 border-white flex items-center justify-center cursor-pointer hover:bg-[#4182fa] hover:border-[#4182fa] transition-all shadow-sm z-10" do %>
              <i class="fa fa-camera text-lg text-white group-hover:text-white"></i>
            <% end %>

            <%= f.file_field :avatar, class: "hidden", accept: 'image/*' %>
          </div>
        </div>

        <div class="max-w-lg mx-auto space-y-8 text-center">

          <div>
            <%= f.label :nickname, "ユーザーネーム", class: "block text-xl font-black text-[#1f2937] mb-2 tracking-widest border-b-2 border-[#c7d2fe] inline-block px-8 pb-1" %>
            <%= f.text_field :nickname, class: "w-full bg-[#f4f6fb] border--[#c7d2fe] text-[#1f2937] text-center font-bold text-lg rounded-full py-3 px-6 shadow-inner focus:ring-2 focus:ring-[#4182fa] focus:border-[#4182fa] placeholder-[#94a3b8] transition-all", placeholder: "ユーザーネームを入力" %>
          </div>

          <div class="text-left">
            <%= f.label :bio, "自己紹介", class: "block text-sm font-bold text-[#1f2937] mb-2 ml-4" %>
            <%= f.text_area :bio, rows:6, class: "w-full bg-[#f4f6fb] border-none text-[#1f2937] rounded-xl p-6 shadow-inner focus:ring-2 focus:ring-[#4182fa] placeholder-[#94a3b8] resize-none", placeholder: "自己紹介文を入力してください" %>
          </div>

        </div>

        <div class="mt-8 flex justify-end">
          <%= f.submit '保存', class: "bg-[#4182fa] hover:bg-[#2563eb] text-white font-block text-lg py-3 px-12 rounded-full shadow-lg transform hover:-translate-y-1 transition-all duration-200 cursor-pointer border-b-4 border-[#2563eb] active:border-b-0 active:translate-y-0" %>
        </div>

      </div>
    <% end %>
  </div>
</div>

