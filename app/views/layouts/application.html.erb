<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Portfolio Device App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://kit.fontawesome.com/03f0c5c061.js" crossorigin="anonymous"></script>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#0b1220] text-[#1f2937] min-h-screen font-sans antialiased flex flex-col">
    <%= render "shared/navbar" %>

    <% flash.each do |key, value| %>
      <% if value.is_a?(String) %>
        <div data-controller="flash" class="fixed top-5 right-5 z-50 p-4 rounded-lg shadow-xl text-[#f4f6fb] font-bold <%= key == 'notice' ? 'bg-blue-500' : 'bg-red-500' %>">
          <div class="flex items-center gap-3">
            <span><%= value %></span>
            <button data-action="click->flash#dismiss" class="hover:text-[#94a3b8]">
              <i class="fa-solid fa-times"></i>
            </button>
          </div>
        </div>
      <% end %>
    <% end %>
    <main class="flex-grow">
      <%= yield %>
    </main>
    <% if controller_name == 'desk_setups' %>
      <%= render 'shared/fab' %>
    <% end %>

    <%= render 'shared/footer' %>
  </body>
</html>
