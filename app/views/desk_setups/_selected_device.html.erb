<div id="selected_device_<%= device.id %>" class="flex items-center justify-between p-3 bg-white border border-[#c7d2fe] rounded-lg shadow-sm mb-3 w-full group hover:shadow-md transition-all duration-200">
  
  <div class="flex items-center gap-3 overflow-hidden">
    <div class="flex-shrink-0 w-12 h-12 bg-[#f4f6fb] rounded-md flex items-center justify-center overflow-hidden border border-[#c7d2fe]">
      <% if device.images.attached? %>
        <%= image_tag device.image, class: "w-full h-full object-cover" %>
      <% else %>
        <span class="text-[10px] text-[#c7d2fe] text-lg">No Img</span>
      <% end %>
    </div>

    <div class="min-w-0">
      <p class="text-[10px] text-[#4182fa] font-bold leading-tight truncate uppercase tracking-wider">
        <%= device.brand_name %>
      </p>
      <p class="text-sm text-[#1f2937] font-bold leading-tight truncate">
        <%= device.name %>
      </p>
    </div>
  </div>

  <input type="hidden" name="desk_setup[device_ids][]" value="<%= device.id %>">

  <button type="button" onclick="this.closest('div[id^=selected_device_]').remove()" 
    class="flex-shrink-0 ml-2 text-[#94a3b8] hover:text-red-500 hover:bg-red-50 p-2 rounded-full transition-colors duration-200 cursor-pointer">
    <i class="fa-solid fa-xmark text-sm"></i>
  </button>
</div>