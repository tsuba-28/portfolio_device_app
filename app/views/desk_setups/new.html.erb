<div class="container mx-auto px-4 py-8 max-w-7xl">
  
  <h1 class="text-3xl font-black mb-8 text-[#4182fa] tracking-tight">
    <i class="fas fa-microchip mr-2"></i>NEW DESK SETUP
  </h1>

  <%= form_with model: @desk_setup, local: true do |f| %>
    <%= render partial: 'shared/error_messages', locals: { object: f.object } %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <div class="lg:col-span-2 space-y-6">
      
        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <%= render 'image_form', f: f %>
        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <div>
              <%= f.label :style_id, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
                <i class="fas fa-layer-group text-[#4182fa]"></i> スタイル / テーマ
                <span class="ml-2 px-2 py-0.5 text-[10px] bg-[#4182fa]/10 text-[#4182fa] border border-[#4182fa]/30 rounded vertical-middle">必須</span>
              <% end %>
              <%= f.collection_select :style_id, Style.order(position: :asc), :id, :name, { include_blank: "選択してください" }, { required: true, class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] focus:border-[#4182fa] focus:ring-[#4182fa] hover:cursor-pointer" } %>
            </div>

            <div>
              <%= f.label :tag_list, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
                <i class="fas fa-tags text-[#4182fa]"></i> タグ
              <% end %>
              <%= f.select :tag_list, 
                  DeskSetup.tags_on(:tags).map { |t| [t.name, t.name] },
                  { include_blank: true },
                  { multiple: true, data: { controller: "tags" }, class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] focus:border-[#4182fa] focus:ring-[#4182fa]" }
              %>
            </div>
          </div>
        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <%= f.label :title, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
            <i class="fas fa-keyboard text-[#4182fa]"></i> タイトル
            <span class="ml-2 px-2 py-0.5 text-[10px] bg-[#4182fa]/10 text-[#4182fa] border border-[#4182fa]/30 rounded vertical-middle">必須</span>
          <% end %>
          <%= f.text_field :title, required: true, class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] placeholder-[#94a3b8] focus:border-[#4182fa] focus:ring-[#4182fa]", placeholder: "タイトルを追加" %>
        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <%= f.label :content, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
            <i class="fas fa-comment-dots text-[#4182fa]"></i> コメント
          <% end %>
          <%= f.text_area :content, rows: 8, class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] placeholder-[#94a3b8] focus:border-[#4182fa] focus:ring-[#4182fa]", placeholder: "こだわりのポイントや、使用している機材の裏話などを教えてください" %>
        </div>
      </div>

      <div class="space-y-6">

        <div data-controller="device-picker" class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm sticky top-4">
          <h2 class="text-lg font-bold text-[#4182fa] mb-4 flex items-center gap-2">
            <i class="fas fa-microchip"></i> 使用デバイス
          </h2> 

          <button type="button" 
                  data-action="click->device-picker#toggle" 
                  data-device-picker-target="toggleButton" 
                  class="w-full py-2 px-4 border-2 border-[#4182fa] text-[#4182fa] font-bold rounded-lg hover:bg-blue-50 transition-colors mb-4 flex items-center justify-center hover:cursor-pointer gap-2">
            <i class="fas fa-plus"></i> デバイス追加
          </button>

          <div data-device-picker-target="searchArea" class="hidden mb-4 relative">
            <input type="text" 
                    placeholder="デバイスを検索..." 
                    data-action="keydown->device-picker#search" 
                    class="w-full pl-3 pr-3 py-2 bg-white border border-[#c7d2fe] rounded-md focus:outline-none focus:ring-2 focus:ring-[#4182fa] text-[#1f2937] text-sm placeholder-[#94a3b8]">

            <div class="mt-2 border border-[#c7d2fe] rounded-md max-h-60 overflow-y-auto bg-white">
              <%= turbo_frame_tag "search_results" do %>
                <p class="text-xs text-[#94a3b8] p-4 text-center">ここに検索結果が表示されます</p>
              <% end %>
            </div>
          </div>

          <div id="selected_devices" data-device-picker-target="selectedList" class="space-y-3">
            </div>

        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <p class="text-xs text-[#94a3b8] mb-3 text-center">
            入力内容を確認して投稿してください
          </p>
          <%= f.submit '投稿する', class: "w-full bg-[#4182fa] hover:bg-[#2563eb] text-white font-bold py-3 px-4 rounded-lg transition-all duration-200 shadow-md hover:shadow-lg transform hover:-translate-y-0.5 cursor-pointer" %>
        </div>

      </div>
    </div>
  <% end %>
</div>