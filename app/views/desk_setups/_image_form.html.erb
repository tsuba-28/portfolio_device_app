<div data-controller="images" class="w-full">
  <div class="flex items-center justify-center w-full">
    
    <%= f.label :images,
      class: "flex flex-col items-center justify-center w-full h-64 border-2 border-dashed border-[#c7d2fe] rounded-xl cursor-pointer bg-[#f8fafc] hover:bg-blue-50 transition-all duration-300 group relative",
      data: {
        images_target: "dropZone", 
        action: "dragover->images#dragOver dragleave->images#dragLeave drop->images#drop"
      } do %>

      <div class="flex flex-col items-center justify-center pt-5 pb-6">
        <i class="far fa-images text-5xl text-[#c7d2fe] mb-4 group-hover:text-[#4182fa] group-hover:scale-110 transition-transform duration-300"></i>
        
        <p class="mb-2 text-sm text-[#1f2937]">
        <span class="font-bold text-[#4182fa]">クリックしてアップロード</span>
        </p>

        <p class="text-xs text-[#94a3b8] font-medium">
          またはドラッグ&ドロップ
            （<span data-images-target="currentCount" class="font-bold text-[#4182fa]">0</span> / <span data-images-target="maxCount"></span>）
        </p>

        <p class="text-xs text-[#c7d2fe] mt-4 font-bold tracking-wider">JPG / PNG （up to 5MB）</p>
      </div>

      <%= f.file_field :images, multiple: true, class: "hidden",
        data: {
          images_target: "input", 
          action: "change->images#preview"
        }
      %>
    <% end %>
  </div>

  <div data-images-target="preview" class="grid lg:grid-cols-5 gap-4 mt-6">
  <%# ここにプレビュー表示 %>
  </div>
</div>