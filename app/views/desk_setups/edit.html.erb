<div class="container mx-auto px-4 py-8 max-w-7xl">
  
  <h1 class="text-3xl font-black mb-8 text-[#4182fa] tracking-tight">
    <i class="fas fa-keyboard mr-2"></i><%= @desk_setup.title %>
  </h1>

  <%= form_with model: @desk_setup, local: true do |f| %>
    <%= render 'shared/error_messages', object: f.object %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <div class="lg:col-span-2 space-y-6">
      
        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm mb-6" data-controller="images">
          <h2 class="text-sm font-bold text-[#1f2937] mb-4 flex items-center gap-2">
            <i class="fas fa-images text-[#4182fa]"></i> 投稿済みの画像（削除のみ）
          </h2>

          <div class="grid lg:grid-cols-5 gap-4">
            <% if @desk_setup.images.attached? %>
              <% @desk_setup.images.each do |image| %>
                <div class="relative group aspect-[3/4]" data-images-target="existingImage">
                  <%= image_tag image.variant(resize_to_limit: [200, 200]), class: "w-full h-full object-cover rounded-lg border border-[#c7d2fe] shadow-sm" %>

                  <%= check_box_tag "desk_setup[delete_image_ids][]", image.id, false, class: "hidden", data: { images_target: "deleteCheckbox" } %>

                  <button type="button" class="absolute -top-2 -right-2 bg-white hover:bg-red-500 text-slate-500 hover:text-white rounded-lg shadow-md transition-colors duration-200 flex items-center justify-center w-7 h-7" 
                          data-action="click->images#markForDeletion">
                    <i class="fa-solid fa-times text-xs"></i>
                  </button>
                </div>
              <% end %>
            <% end %>
          </div>

          <p class="text-[10px] text-[#94a3b8] mt-4">※ 画像を追加する機能は現在準備中です。削除のみ行えます。</p>
        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <div>
              <%= f.label :style_id, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
                <i class="fas fa-layer-group text-[#4182fa]"></i> スタイル / テーマ
              <% end %>
              <%= f.collection_select :style_id, Style.order(position: :asc), :id, :name, { include_blank: "選択してください" }, { class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] focus:border-[#4182fa] focus:ring-[#4182fa]" } %>
            </div>

            <div>
              <%= f.label :tag_list, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
                <i class="fas fa-tags text-[#4182fa]"></i> タグ
              <% end %>
              <%= f.select :tag_list, 
                  DeskSetup.tags_on(:tags).map { |t| [t.name, t.name] },
                  { include_blank: true },
                  { multiple: true, data: { controller: "tags" }, class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] focus:border-[#4182fa] focus:ring-[#4182fa]" }
              %>
            </div>
          </div>
        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <%= f.label :title, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
            <i class="fas fa-keyboard text-[#4182fa]"></i> タイトル
          <% end %>
          <%= f.text_field :title, class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] placeholder-[#94a3b8] focus:border-[#4182fa] focus:ring-[#4182fa]", placeholder: "タイトルを追加" %>
        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <%= f.label :content, class: "flex items-center gap-2 mb-2 text-sm font-bold text-[#1f2937]" do %>
            <i class="fas fa-comment-dots text-[#4182fa]"></i> コメント
          <% end %>
          <%= f.text_area :content, rows: 8, class: "w-full bg-white border-[#c7d2fe] rounded-md text-[#1f2937] placeholder-[#94a3b8] focus:border-[#4182fa] focus:ring-[#4182fa]", placeholder: "こだわりのポイントや、使用している機材の裏話などを教えてください" %>
        </div>
      </div>

      <div class="space-y-6">

        <div data-controller="device-picker" class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm sticky top-4">
          <h2 class="text-lg font-bold text-[#4182fa] mb-4 flex items-center gap-2">
            <i class="fas fa-cubes"></i> 登録済みデバイス
          </h2> 

          <button type="button" 
                  data-action="click->device-picker#toggle" 
                  data-device-picker-target="toggleButton" 
                  class="w-full py-2 px-4 border-2 border-[#4182fa] text-[#4182fa] font-bold rounded-lg hover:bg-blue-50 transition-colors mb-4 flex items-center justify-center gap-2">
            <i class="fas fa-chevron-down"></i> 全てのデバイスを見る
          </button>

          <div data-device-picker-target="searchArea" class="hidden mb-4 relative">

            <div id="selected_devices" data-device-picker-target="selectedList" class="space-y-3">
              <div class="flex flex-nowrap overflow-x-auto gap-4 pb-4 scrollbar-hide">
                <% if @desk_setup.devices.present? %>
                  <% @desk_setup.devices.each do |device| %>
                    <div class="relative group flex-none w-48 " data-device-picker-target="existingDevice">
                      <%= render 'shared/device_card', device: device %>

                      <%= check_box_tag "desk_setup[delete_device_ids][]", device.id, false, class: "hidden", data: { device_picker_target: "deleteCheckbox" } %>

                      <button type="button" class="absolute -top-2 -right-2 z-10 bg-white hover:bg-red-500 text-slate-500 hover:text-white rounded-lg shadow-md transition-colors duration-200 flex items-center justify-center w-7 h-7" 
                        data-action="click->device-picker#markForDeletion">
                          <i class="fa-solid fa-times text-xs"></i>
                      </button>
                    </div>
                  <% end %>
                <% else %>
                  <div class="col-span-full py-12 flex flex-col items-center justify-center text-center">
                    <p class="text-[#2563eb] font-black mb-4 leading-relaxed">
                    登録されているデバイスがありません
                    </p>
                  </div>
                <% end %>
              </div>
            </div>
          </div>

        </div>

        <div class="bg-[#f4f6fb] p-6 rounded-xl border border-[#c7d2fe] shadow-sm">
          <p class="text-xs text-[#94a3b8] mb-3 text-center">
            入力内容を確認して更新してください
          </p>
          <%= f.submit '更新する', class: "w-full bg-[#4182fa] hover:bg-[#2563eb] text-white font-bold py-3 px-4 rounded-lg transition-all duration-200 shadow-md hover:shadow-lg transform hover:-translate-y-0.5 cursor-pointer" %>
        </div>

      </div>
    </div>
  <% end %>
</div>