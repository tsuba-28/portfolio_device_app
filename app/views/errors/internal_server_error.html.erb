<% content_for :title, "500 Internal Server Error" %>

<div class="flex flex-col items-center justify-center text-center px-4">

  <div class="relative">
    <h1 class="text-[120px] md:text-[200px] font-black text-transparent bg-clip-text bg-gradient-to-b from-[#ef4444] to-slate-800 leading-none select-none">
      500
    </h1>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-20">

      <i class="fa-solid fa-triangle-exclamation text-[100px] text-[#ef4444] blur-sm"></i>
    </div>
  </div>

  <div class="max-w-2xl space-y-6 -mt-4 md:-mt-8">
    <h2 class="text-2xl md:text-3xl font-bold text-[#f4f6fb] tracking-tight">
      System Error
    </h2>

    <p class="text-[#94a3b8] leading-relaxed">
      申し訳ありません。サーバー側で一時的な問題が発生しています。<br>
      時間を置いて再度お試しください。
    </p>

    <div class="pt-8">
      <%= link_to root_path, class: "inline-flex items-center gap-2 bg-slate-700 hover:bg-slate-600 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 shadow-lg shadow-black/20 hover:shadow-black/40 transform hover:-translate-y-1" do %>
        <i class="fa-solid fa-rotate-left"></i>
        トップページへ
      <% end %>
    </div>
  </div>

  <div class="mt-20 flex gap-4 text-[#ef4444]/20 text-4xl">
    <i class="fa-solid fa-gears animate-spin" style="animation-duration: 3s;"></i>
    <i class="fa-solid fa-bolt animate-pulse"></i>
    <i class="fa-solid fa-wrench animate-bounce" style="animation-delay: 0.5s;"></i>
  </div>
</div>