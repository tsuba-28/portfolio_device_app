<div class="bg-[#f4f6fb] rounded-2xl shadow-sm overflow-hidden border-3 border-[#4182fa]/80 hover:border-[#2563eb] transition-all duration-300 h-full">
  
  <%# 1. ユーザーヘッダー部分 %>
  <div class="flex items-center justify-between p-3">
    <%= link_to account_path(setup.user), class: "flex items-center gap-2 group/user" do %>
      <div class="w-8 h-8 rounded-lg overflow-hidden border border-slate-100 shadow-sm">
        <%# .attached? で画像があるかチェックし、image_tag にはデータそのものを渡す %>
        <% if setup.user.profile.avatar.attached? %>
          <%= image_tag setup.user.profile.avatar, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full bg-slate-100 flex items-center justify-center">
            <i class="fas fa-user text-slate-300 text-xs"></i>
          </div>
        <% end %>
      </div>
      
      <div class="flex flex-col">
        <span class="text-[11px] font-bold text-slate-700 leading-none group-hover/user:text-[#4182fa] transition-colors">
          <%= setup.user.profile.nickname %>
        </span>
      </div>
    <% end %>
  </div>

  <%# 2. メイン画像部分（重複を削除し、hover演出を適用） %>
  <div class="overflow-hidden h-48">
    <% if setup.images.attached? %>
      <%= image_tag setup.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
    <% end %>
  </div>

  <%# 3. コンテンツ部分 %>
  <div class="p-4">
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs px-2 py-1 bg-[#4182fa]/10 text-[#4182fa] rounded-md font-bold">
        <%= setup.style.name %>
      </span>
    </div>
    <h2 class="font-bold text-[#1f2937] mb-2 truncate"><%= setup.title %></h2>
    
    <div class="flex flex-wrap gap-2 mb-4">
      <% setup.tag_list.each do |tag| %>
        <span class="text-[10px] px-2 py-0.5 border border-[#4182fa]/30 text-[#4182fa] rounded-md font-medium bg-[#f4f6fb]/50">#<%= tag %></span>
      <% end %>
    </div>
    
    <%= link_to "詳細を見る", desk_setup_path(setup), class: "block w-full text-center py-2 bg-[#f4f6fb] text-[#4182fa] text-sm font-bold rounded-lg hover:bg-[#4182fa] hover:text-[#f4f6fb] transition-all border border-[#4182fa]/20" %>
  </div>
</div>