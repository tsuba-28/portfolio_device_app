<div class="container mx-auto px-4 py-8 max-w-7xl">

  <div class="text-center mb-16">
    <h1 class="text-4xl md:text-6xl font-black text-white mb-4 tracking-tighter italic">
      <span class="text-[#4182fa]">お気に入りした投稿</span>
    </h1>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% if @desk_setups.present? %>
      <% @desk_setups.each do |setup| %>
        <div class="flex-none">
          <%= render 'shared/desk_setup_card', setup: setup %>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-full text-center py-20">
        <p class="text-slate-500">まだお気に入りに追加していません。お気に入りの投稿を見つけましょう！</p>
      </div>
    <% end %>
  </div>
</div>